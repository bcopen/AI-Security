  "sensitive_data_patterns": {
    "description": "敏感信息检测正则",
    "patterns": [
      {"pattern": "api[_-]?key[\"']?\\s*[:=]\\s*[\"']?[\\w-]{20,}", "type": "API Key", "severity": "critical"},
      {"pattern": "secret[\"']?\\s*[:=]\\s*[\"']?[\\w-]{20,}", "type": "密钥", "severity": "critical"},
      {"pattern": "password[\"']?\\s*[:=]\\s*[\"']?[^\\s\"\\'<]{6,}", "type": "密码", "severity": "critical"},
      {"pattern": "token[\"']?\\s*[:=]\\s*[\"']?[\\w-]{20,}", "type": "Token", "severity": "high"},
      {"pattern": "Bearer\\s+[\\w-]+\\.?[\\w-]*", "type": "Bearer Token", "severity": "high"},
      {"pattern": "eyJ[A-Za-z0-9_-]*\\.eyJ[A-Za-z0-9_-]*\\.[A-Za-z0-9_-]*", "type": "JWT", "severity": "high"},
      {"pattern": "aws[_-]?access[_-]?key[_-]?id[\"']?\\s*[:=]\\s*[\"']?[\\w-]{20,}", "type": "AWS Key", "severity": "critical"},
      {"pattern": "-----BEGIN\\s+(RSA\\s+)?PRIVATE\\s+KEY-----", "type": "私钥", "severity": "critical"},
      {"pattern": "github[_-]?token[\"']?\\s*[:=]\\s*[\"']?[\\w-]{20,}", "type": "GitHub Token", "severity": "high"},
      {"pattern": "connection[_-]?string[\"']?\\s*[:=]\\s*[\"']?[^\\s\"\\'<]{20,}", "type": "数据库连接", "severity": "critical"}
    ]
  },
  
