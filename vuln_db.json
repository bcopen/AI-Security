  "security_headers": {
    "description": "必需的安全响应头",
    "headers": [
      {"name": "Strict-Transport-Security", "severity": "high", "description": "启用HSTS", "recommendation": "max-age=31536000; includeSubDomains"},
      {"name": "Content-Security-Policy", "severity": "high", "description": "内容安全策略", "recommendation": "default-src 'self'"},
      {"name": "X-Content-Type-Options", "severity": "medium", "description": "防止MIME sniffing", "recommendation": "nosniff"},
      {"name": "X-Frame-Options", "severity": "medium", "description": "防止点击劫持", "recommendation": "DENY or SAMEORIGIN"},
      {"name": "Referrer-Policy", "severity": "low", "description": "引用策略", "recommendation": "strict-origin-when-cross-origin"},
      {"name": "Permissions-Policy", "severity": "low", "description": "浏览器功能策略", "recommendation": "geolocation=(), microphone=()"},
      {"name": "X-XSS-Protection", "severity": "low", "description": "XSS过滤器", "recommendation": "1; mode=block"}
    ]
